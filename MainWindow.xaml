<Window x:Class="ATASChinesePatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ATAS Chinese Patch"
        Height="760"
        Width="1080"
        MinHeight="680"
        MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="ATAS 安装目录"
                       VerticalAlignment="Center"
                       Margin="0,0,10,8" />
            <TextBox x:Name="InstallPathTextBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,8" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Width="110"
                    Height="34"
                    Margin="0,0,0,8"
                    Content="浏览"
                    Click="BrowseInstallPathButton_Click" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="ATAS 数据目录"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <TextBox x:Name="DataPathTextBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,0" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Width="110"
                    Height="34"
                    Content="浏览"
                    Click="BrowseDataPathButton_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="替换字体"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="ReplacementFontComboBox"
                      Grid.Column="1"
                      Height="34"
                      VerticalContentAlignment="Center"
                      SelectedIndex="0">
                <ComboBoxItem Content="SimSun" />
                <ComboBoxItem Content="Microsoft YaHei" />
                <ComboBoxItem Content="Microsoft YaHei UI" />
                <ComboBoxItem Content="SimHei" />
                <ComboBoxItem Content="Noto Sans CJK SC" />
                <ComboBoxItem Content="Source Han Sans SC" />
            </ComboBox>

            <Button x:Name="ScanFoldersButton"
                    Grid.Column="2"
                    Width="110"
                    Height="34"
                    Margin="12,0,0,0"
                    Content="扫描目录"
                    Click="ScanFoldersButton_Click" />
            <Button x:Name="PatchSelectedButton"
                    Grid.Column="3"
                    Width="120"
                    Height="34"
                    Margin="8,0,0,0"
                    Content="修改已勾选"
                    Click="PatchSelectedButton_Click" />
            <CheckBox x:Name="OverwriteCheckBox"
                      Grid.Column="4"
                      Margin="12,0,0,0"
                      VerticalAlignment="Center"
                      Content="备份后覆盖原 DLL" />
            <Button Grid.Column="6"
                    Width="110"
                    Height="34"
                    Content="打开输出目录"
                    Click="OpenOutputDirectoryButton_Click" />
        </Grid>

        <DataGrid x:Name="CandidateDataGrid"
                 Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="改"
                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="48" />
                <DataGridTextColumn Header="状态"
                                    Binding="{Binding Status}"
                                    IsReadOnly="True"
                                    Width="130" />
                <DataGridTextColumn Header="字体"
                                    Binding="{Binding DetectedFontsText}"
                                    IsReadOnly="True"
                                    Width="210" />
                <DataGridTextColumn Header="命中"
                                    Binding="{Binding DetectedCount}"
                                    IsReadOnly="True"
                                    Width="70" />
                <DataGridTextColumn Header="DLL 路径"
                                    Binding="{Binding Path}"
                                    IsReadOnly="True"
                                    Width="*" />
                <DataGridTextColumn Header="输出"
                                    Binding="{Binding OutputPath}"
                                    IsReadOnly="True"
                                    Width="260" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBox x:Name="LogTextBox"
                 Grid.Row="3"
                 Margin="0,12,0,0"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 FontFamily="Consolas"
                 FontSize="13"
                 HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>
